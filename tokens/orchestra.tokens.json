{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Orchestra Design System tokens. Semantic tokens are the public API; raw palette values are internal and may change. Themes: light, dark.",
  "meta": {
    "name": "Orchestra",
    "prefix": "orc",
    "version": "0.1.0"
  },
  "color": {
    "palette": {
      "$description": "Internal ramps. Do not reference directly from product code; use semantic tokens.",
      "neutral": {
        "0": { "$value": "#FFFFFF" },
        "50": { "$value": "#F6F7F9" },
        "100": { "$value": "#EEF0F3" },
        "200": { "$value": "#D9DEE4" },
        "300": { "$value": "#B3BAC4" },
        "400": { "$value": "#8A93A1" },
        "500": { "$value": "#6B7280" },
        "600": { "$value": "#4B5563" },
        "700": { "$value": "#2A3444" },
        "800": { "$value": "#1F2937" },
        "900": { "$value": "#111827" },
        "950": { "$value": "#0B1220" }
      },
      "indigo": {
        "100": { "$value": "#EEF2FF" },
        "400": { "$value": "#818CF8" },
        "600": { "$value": "#4F46E5" },
        "700": { "$value": "#4338CA" }
      },
      "green": {
        "100": { "$value": "#ECFDF3" },
        "400": { "$value": "#4ADE80" },
        "600": { "$value": "#15803D" }
      },
      "amber": {
        "100": { "$value": "#FFF7E8" },
        "400": { "$value": "#FBBF24" },
        "600": { "$value": "#B45309" }
      },
      "red": {
        "100": { "$value": "#FEF1F1" },
        "400": { "$value": "#F87171" },
        "600": { "$value": "#B91C1C" }
      },
      "cyan": {
        "100": { "$value": "#E9F8FB" },
        "400": { "$value": "#22D3EE" },
        "600": { "$value": "#0E7490" }
      },
      "blue": {
        "100": { "$value": "#EFF4FF" },
        "400": { "$value": "#60A5FA" },
        "600": { "$value": "#1D4ED8" }
      }
    },
    "semantic": {
      "$description": "Public color API. One entry per UI meaning; each has a light and dark theme value.",
      "bg": {
        "canvas": { "light": "#F6F7F9", "dark": "#0B1220" },
        "surface": { "light": "#FFFFFF", "dark": "#111827" },
        "surface-raised": { "light": "#FFFFFF", "dark": "#1F2937" },
        "surface-sunken": { "light": "#EEF0F3", "dark": "#0B1220" }
      },
      "border": {
        "default": { "light": "#D9DEE4", "dark": "#2A3444" },
        "strong": { "light": "#B3BAC4", "dark": "#4B5563" },
        "focus": { "light": "#4F46E5", "dark": "#818CF8" }
      },
      "text": {
        "primary": { "light": "#111827", "dark": "#F3F4F6" },
        "secondary": { "light": "#4B5563", "dark": "#B3BAC4" },
        "tertiary": { "light": "#6B7280", "dark": "#8A93A1" },
        "inverse": { "light": "#FFFFFF", "dark": "#0B1220" },
        "on-accent": { "light": "#FFFFFF", "dark": "#0B1220" }
      },
      "mission": {
        "$description": "Brand accent. Mission identity, primary actions, focus.",
        "accent": { "light": "#4F46E5", "dark": "#818CF8" },
        "accent-hover": { "light": "#4338CA", "dark": "#A5B4FC" },
        "subtle": { "light": "#EEF2FF", "dark": "#1E2340" }
      },
      "progress": {
        "$description": "Completion, success, validated states.",
        "accent": { "light": "#15803D", "dark": "#4ADE80" },
        "subtle": { "light": "#ECFDF3", "dark": "#122B1D" }
      },
      "decision": {
        "$description": "Pending human judgment. The only hue allowed to interrupt.",
        "accent": { "light": "#B45309", "dark": "#FBBF24" },
        "subtle": { "light": "#FFF7E8", "dark": "#2D2411" }
      },
      "risk": {
        "high": { "light": "#B91C1C", "dark": "#F87171" },
        "high-subtle": { "light": "#FEF1F1", "dark": "#2E1616" },
        "medium": { "light": "#B45309", "dark": "#FBBF24" },
        "medium-subtle": { "light": "#FFF7E8", "dark": "#2D2411" },
        "low": { "light": "#6B7280", "dark": "#8A93A1" },
        "low-subtle": { "light": "#EEF0F3", "dark": "#1F2937" }
      },
      "frozen": {
        "$description": "Locked decisions. Deliberately cold hue, visually distinct from risk and decision.",
        "accent": { "light": "#0E7490", "dark": "#22D3EE" },
        "subtle": { "light": "#E9F8FB", "dark": "#0F2A31" }
      },
      "info": {
        "accent": { "light": "#1D4ED8", "dark": "#60A5FA" },
        "subtle": { "light": "#EFF4FF", "dark": "#16233F" }
      }
    }
  },
  "typography": {
    "font-family": {
      "ui": { "$value": "'Inter', -apple-system, 'Segoe UI', Roboto, sans-serif" },
      "mono": { "$value": "'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace" }
    },
    "role": {
      "$description": "Type roles map 1:1 to the information hierarchy. Do not invent ad-hoc sizes.",
      "mission": { "size": "28px", "line-height": "34px", "weight": 650, "tracking": "-0.01em" },
      "section": { "size": "20px", "line-height": "28px", "weight": 600, "tracking": "-0.005em" },
      "card-title": { "size": "16px", "line-height": "24px", "weight": 600, "tracking": "0" },
      "body": { "size": "14px", "line-height": "22px", "weight": 400, "tracking": "0" },
      "label": { "size": "13px", "line-height": "18px", "weight": 500, "tracking": "0" },
      "meta": { "size": "12px", "line-height": "16px", "weight": 400, "tracking": "0" },
      "overline": { "size": "11px", "line-height": "16px", "weight": 600, "tracking": "0.06em", "transform": "uppercase" },
      "code": { "size": "13px", "line-height": "20px", "weight": 400, "family": "mono" }
    }
  },
  "space": {
    "$description": "4px base scale.",
    "1": { "$value": "4px" },
    "2": { "$value": "8px" },
    "3": { "$value": "12px" },
    "4": { "$value": "16px" },
    "5": { "$value": "20px" },
    "6": { "$value": "24px" },
    "8": { "$value": "32px" },
    "10": { "$value": "40px" },
    "12": { "$value": "48px" },
    "16": { "$value": "64px" }
  },
  "radius": {
    "sm": { "$value": "6px" },
    "md": { "$value": "10px" },
    "lg": { "$value": "14px" },
    "pill": { "$value": "999px" }
  },
  "elevation": {
    "$description": "Calm surfaces. Elevation communicates layer, never decoration.",
    "0": { "$value": "none" },
    "1": { "$value": "0 1px 2px rgba(15, 23, 42, 0.06)" },
    "2": { "$value": "0 2px 8px rgba(15, 23, 42, 0.10)" },
    "3": { "$value": "0 8px 24px rgba(15, 23, 42, 0.16)" }
  },
  "motion": {
    "$description": "Calm motion. Nothing animates to attract attention except decision arrival.",
    "duration": {
      "fast": { "$value": "120ms" },
      "base": { "$value": "200ms" },
      "slow": { "$value": "320ms" }
    },
    "easing": {
      "standard": { "$value": "cubic-bezier(0.2, 0, 0, 1)" },
      "enter": { "$value": "cubic-bezier(0, 0, 0.2, 1)" },
      "exit": { "$value": "cubic-bezier(0.4, 0, 1, 1)" }
    }
  },
  "z-index": {
    "surface": { "$value": 0 },
    "sticky": { "$value": 100 },
    "drawer": { "$value": 200 },
    "interrupt": { "$value": 300 },
    "toast": { "$value": 400 }
  }
}
